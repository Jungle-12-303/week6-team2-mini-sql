#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS_NAME="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH_NAME="$(uname -m)"
BIN_PATH="$ROOT_DIR/.build/${OS_NAME}-${ARCH_NAME}/mini_sql.bin"

if [[ ! -x "$BIN_PATH" ]]; then
  echo "mini_sql binary not found for ${OS_NAME}-${ARCH_NAME}." >&2
  echo "Run 'make mini_sql' for local builds or 'make cli' for Docker Linux mode." >&2
  exit 1
fi

exec "$BIN_PATH" "$@"
